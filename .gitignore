# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.venv/

# Jupyter
.ipynb_checkpoints/

# Data files — tracked by DVC, not Git
data/raw/*
data/processed/*
data/external/*

# Allow DVC pointer files and gitkeep through
!data/raw/*.dvc
!data/processed/*.dvc
!data/external/*.dvc
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# MLflow
mlruns/
mlflow.db

# DVC
.dvc/cache
.dvc/tmp

# Environment variables
.env

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Docker
*.log

# Ignore raw dataset archives and text files
data/raw/*.txt
data/raw/*.json
data/raw/*.tar
data/raw/*.gz

# Pipeline artifacts
pipeline_manifest.json
logs/
*.log

# Environment secrets
.env

# MLflow local artifacts
mlruns/
mlflow.db

/models_store

# Allow model artifacts in Git (needed for Render deployment)
!models_store/tfidf_vectorizer.pkl
!models_store/tfidf_matrix.npz
!models_store/sentence_embeddings.npy
!models_store/faiss_semantic.index
!models_store/metadata.csv

# Allow processed data CSVs
!data/raw/books_raw.csv
!data/raw/papers_raw.csv
!data/processed/combined_processed.csv
